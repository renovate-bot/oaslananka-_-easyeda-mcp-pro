{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oaslananka/easyeda-mcp-pro/tests/fixtures/golden/fixture-schema.json",
  "title": "Golden EasyEDA Pro E2E Fixture Schema",
  "description": "Defines the structure of a deterministic EasyEDA Pro golden fixture for end-to-end workflow validation.",
  "type": "object",
  "required": [
    "fixtureName",
    "fixtureVersion",
    "schemaVersion",
    "description",
    "board",
    "schematic",
    "bom",
    "erc",
    "drc",
    "exportManifest",
    "metadata"
  ],
  "properties": {
    "fixtureName": {
      "type": "string",
      "description": "Human-readable name of the fixture"
    },
    "fixtureVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the fixture definition"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of this fixture schema"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the fixture board and purpose"
    },
    "board": {
      "type": "object",
      "description": "Board-level metadata and expected properties",
      "required": ["expectedLayers", "expectedDimensions", "expectedFeatures"],
      "properties": {
        "expectedLayers": {
          "type": "integer",
          "minimum": 2,
          "maximum": 64,
          "description": "Expected number of PCB layers"
        },
        "expectedDimensions": {
          "type": "object",
          "required": ["width_mm", "height_mm"],
          "properties": {
            "width_mm": { "type": "number", "minimum": 1 },
            "height_mm": { "type": "number", "minimum": 1 }
          }
        },
        "expectedFeatures": {
          "type": "object",
          "description": "Expected board feature counts",
          "required": ["vias", "tracks", "zones", "pads", "components"],
          "properties": {
            "vias": { "type": "integer", "minimum": 0 },
            "tracks": { "type": "integer", "minimum": 0 },
            "zones": { "type": "integer", "minimum": 0 },
            "pads": { "type": "integer", "minimum": 0 },
            "components": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "schematic": {
      "type": "object",
      "description": "Expected schematic state",
      "required": ["components", "namedNets", "totalNets"],
      "properties": {
        "components": {
          "type": "array",
          "description": "Expected schematic components with reference designators",
          "items": {
            "type": "object",
            "required": ["ref", "description", "package"],
            "properties": {
              "ref": {
                "type": "string",
                "pattern": "^[A-Z][0-9]+$",
                "description": "Reference designator (e.g., R1, U1, C1)"
              },
              "description": {
                "type": "string",
                "description": "Component description / value"
              },
              "package": {
                "type": "string",
                "description": "Footprint / package name"
              },
              "lcsc": {
                "type": "string",
                "pattern": "^C\\d+$",
                "description": "LCSC part number if applicable"
              },
              "quantity": {
                "type": "integer",
                "minimum": 1,
                "default": 1,
                "description": "Quantity used on the board"
              },
              "category": {
                "type": "string",
                "enum": ["IC", "Passive", "Connector", "Electromechanical", "Power", "Other"],
                "description": "Component category for BOM grouping"
              }
            }
          },
          "uniqueItemProperties": ["ref"]
        },
        "namedNets": {
          "type": "array",
          "description": "Expected named (non-autogenerated) nets",
          "items": {
            "type": "object",
            "required": ["name", "nodes"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Net name"
              },
              "nodes": {
                "type": "array",
                "description": "Pin connections on this net (ref.pin format)",
                "items": {
                  "type": "string",
                  "pattern": "^[A-Z][0-9]+\\.[A-Za-z0-9_]+$"
                },
                "minItems": 1
              }
            }
          },
          "uniqueItemProperties": ["name"]
        },
        "totalNets": {
          "type": "integer",
          "minimum": 1,
          "description": "Expected total number of nets (including auto-generated)"
        }
      }
    },
    "bom": {
      "type": "object",
      "description": "Expected Bill of Materials structure and content",
      "required": ["expectedLineCount", "maxLineCostUsd", "lines"],
      "properties": {
        "expectedLineCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Expected number of BOM lines"
        },
        "maxLineCostUsd": {
          "type": "number",
          "minimum": 0,
          "description": "Maximum expected per-line cost anchor for validation"
        },
        "lines": {
          "type": "array",
          "description": "Expected BOM line items",
          "items": {
            "type": "object",
            "required": ["ref", "description", "package", "quantity"],
            "properties": {
              "ref": { "type": "string", "description": "Reference(s) for this line" },
              "description": { "type": "string", "description": "Part description" },
              "package": { "type": "string", "description": "Footprint" },
              "quantity": { "type": "integer", "minimum": 1 },
              "lcsc": { "type": "string", "description": "LCSC part number" }
            }
          },
          "minItems": 1
        }
      }
    },
    "erc": {
      "type": "object",
      "description": "Expected Electrical Rule Check results",
      "required": ["expectedErrorCount", "expectedWarningCount", "maxErrors"],
      "properties": {
        "expectedErrorCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Expected number of ERC errors"
        },
        "expectedWarningCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Expected number of ERC warnings"
        },
        "maxErrors": {
          "type": "integer",
          "minimum": 0,
          "description": "Absolute maximum allowed errors before fixture is invalid"
        }
      }
    },
    "drc": {
      "type": "object",
      "description": "Expected Design Rule Check results",
      "required": ["expectedErrorCount", "expectedWarningCount", "maxErrors"],
      "properties": {
        "expectedErrorCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Expected number of DRC errors"
        },
        "expectedWarningCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Expected number of DRC warnings"
        },
        "maxErrors": {
          "type": "integer",
          "minimum": 0,
          "description": "Absolute maximum allowed errors before fixture is invalid"
        }
      }
    },
    "exportManifest": {
      "type": "object",
      "description": "Expected export outputs and file manifest",
      "required": ["expectedFileCount", "expectedFormats", "files"],
      "properties": {
        "expectedFileCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Expected number of export files"
        },
        "expectedFormats": {
          "type": "array",
          "description": "Expected export formats",
          "items": {
            "type": "string",
            "enum": [
              "gerber",
              "drill",
              "bom_csv",
              "pnp_csv",
              "pdf_schematic",
              "pdf_board",
              "netlist"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "files": {
          "type": "array",
          "description": "Expected export files with metadata",
          "items": {
            "type": "object",
            "required": ["name", "format", "minSizeBytes"],
            "properties": {
              "name": { "type": "string", "description": "Filename" },
              "format": { "type": "string", "description": "File format" },
              "minSizeBytes": {
                "type": "integer",
                "minimum": 1,
                "description": "Minimum expected file size in bytes"
              }
            }
          },
          "minItems": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Fixture metadata and execution requirements",
      "required": [
        "easyedaVersion",
        "bridgeExtensionVersion",
        "serverVersion",
        "requiresLocalEasyEDA"
      ],
      "properties": {
        "easyedaVersion": {
          "type": "string",
          "description": "Required EasyEDA Pro version"
        },
        "bridgeExtensionVersion": {
          "type": "string",
          "description": "Required bridge extension version"
        },
        "serverVersion": {
          "type": "string",
          "description": "Required easyeda-mcp-pro server version"
        },
        "requiresLocalEasyEDA": {
          "type": "boolean",
          "const": true,
          "description": "Must be true — fixture requires local EasyEDA Pro"
        }
      }
    }
  }
}
