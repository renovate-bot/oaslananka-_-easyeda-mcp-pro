# ── Runtime ────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
TOOL_PROFILE=core
# Optional comma/space separated allowlist, e.g. schematic:read,bom:read
TOOL_SCOPES=
MCP_PROTOCOL_VERSION=2025-11-25
# local_bridge keeps the existing localhost extension bridge. remote_relay routes bridge calls through a paired Remote Relay session.
MCP_BRIDGE_BACKEND=local_bridge
# Optional fixed Remote Relay session id for remote_relay backend; otherwise use remoteSessionId per request.
MCP_REMOTE_SESSION_ID=

# ── Transport ──────────────────────────────────────────────
TRANSPORT=stdio
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
HTTP_AUTH_DISABLED=false
HTTP_RATE_LIMIT_MAX=100
# Legacy single-origin helper for local browser clients.
CORS_ORIGIN=
# Required when binding HTTP to a non-loopback interface; wildcard '*' is rejected.
# This browser-origin allowlist does not replace OAuth authentication.
ALLOWED_ORIGINS=

# ── MCP experimental flags ─────────────────────────────────
MCP_TASKS_ENABLED=false
MCP_APPS_ENABLED=false
MCP_V2_EXPERIMENTAL=false
# Second explicit gate for the raw JavaScript execution tool. Keep false unless actively debugging.
MCP_RAW_EXEC_EXPERIMENTAL=false

# ── Bridge ─────────────────────────────────────────────────
# Non-loopback bridge listeners require a strong BRIDGE_TOKEN for pairing.
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=49620
BRIDGE_PORT_SCAN=49620-49629
BRIDGE_TIMEOUT_MS=15000
BRIDGE_HEARTBEAT_MS=10000
BRIDGE_RECONNECT_MAX_ATTEMPTS=0
BRIDGE_MAX_PAYLOAD_SIZE=1048576
BRIDGE_TOKEN=
EASYEDA_DEV_BRIDGE=false
BRIDGE_RAW_EXEC_ENABLED=false
# Dev-only dispatcher hot swap: auto-push a rebuilt extension dispatcher over
# the bridge (no .eext re-import). Refused in production. Point the watch path
# at easyeda-bridge-extension/dist/dispatcher.js.
BRIDGE_HOT_SWAP_ENABLED=false
BRIDGE_HOT_SWAP_WATCH=
BRIDGE_HOT_SWAP_CHUNK_BYTES=65536

# ── Storage ────────────────────────────────────────────────
DATA_DIR=.easyeda-mcp-pro
SQLITE_PATH=.easyeda-mcp-pro/easyeda-mcp-pro.sqlite
ARTIFACT_DIR=.easyeda-mcp-pro/artifacts
CACHE_DIR=.easyeda-mcp-pro/cache

# ── AI assistance ──────────────────────────────────────────
AI_PROVIDER=none
AI_MODEL=
AI_API_KEY=
AI_MAX_TOKENS=8000
AI_TIMEOUT_MS=60000
AI_ALLOW_DESIGN_MUTATIONS=false

# ── JLCPCB official API ────────────────────────────────────
JLCPCB_MODE=disabled
JLCPCB_CLIENT_ID=
JLCPCB_CLIENT_SECRET=
JLCPCB_API_BASE_URL=https://api.jlcpcb.com
JLCPCB_ENABLE_ORDERING=false
JLCPCB_DEFAULT_CURRENCY=USD

# ── LCSC / jlcsearch ───────────────────────────────────────
JLCSEARCH_ENABLED=true
JLCSEARCH_BASE_URL=https://jlcsearch.tscircuit.com
LCSC_API_KEY=
LCSC_API_SECRET=

# ── Mouser ─────────────────────────────────────────────────
MOUSER_ENABLED=false
MOUSER_API_KEY=
MOUSER_API_BASE_URL=https://api.mouser.com

# ── DigiKey ────────────────────────────────────────────────
DIGIKEY_ENABLED=false
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_SANDBOX=true
DIGIKEY_LOCALE=en-US
DIGIKEY_CURRENCY=USD

# ── OAuth for HTTP mode ────────────────────────────────────
# Required with JWKS, issuer, and audience for every non-loopback HTTP listener.
OAUTH_ENABLED=false
OAUTH_ISSUER=
OAUTH_AUDIENCE=easyeda-mcp-pro
OAUTH_JWKS_URI=
# Dot-form scopes match Remote MCP permission docs; legacy easyeda:read is still accepted.
OAUTH_REQUIRED_SCOPES=easyeda.read

# ── Telemetry ──────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=easyeda-mcp-pro
OTEL_EXPORTER_OTLP_ENDPOINT=
TRACE_SAMPLE_RATE=1.0
